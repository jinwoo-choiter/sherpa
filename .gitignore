# Salt file (operator-only, 0400 in operator $HOME). Never check in.
sherpa-salt
sherpa-salt.txt
*.salt

# RAG index artifacts (also belong in a separate repo per spec D8).
rag_index/
*.index
*.npy

# Local logs / audit
logs/
audit/

# OS / editor
.DS_Store
.vscode/
.idea/
